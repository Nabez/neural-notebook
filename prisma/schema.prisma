// Simplified Neural Notebook Schema - Works with SQLite locally

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data.db"
}

// Workspace - Root container
model Workspace {
  id          String   @id @default(cuid())
  name        String   @default("My Workspace")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  notes       Note[]
  folders     Folder[]
}

// Folder - Organization
model Folder {
  id           String   @id @default(cuid())
  name         String
  color        String?
  icon         String?
  canvasX      Float    @default(0)
  canvasY      Float    @default(0)
  canvasWidth  Float    @default(240)
  canvasHeight Float    @default(180)
  parentId     String?
  
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  notes        Note[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Note - All note types
model Note {
  id           String   @id @default(cuid())
  title        String
  content      String
  type         String   @default("TEXT") // TEXT, CANVAS, STICKY, CODE
  tags         String?
  color        String?
  
  canvasX      Float    @default(0)
  canvasY      Float    @default(0)
  canvasWidth  Float    @default(320)
  canvasHeight Float    @default(400)
  
  folderId     String?
  folder       Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Settings - User preferences
model Settings {
  id        String   @id @default("default")
  theme     String   @default("dark")
  gridType  String   @default("dots")
  updatedAt DateTime @updatedAt
}
